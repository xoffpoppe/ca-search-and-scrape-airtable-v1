{
  "title": "CA Search and Scrape - Airtable Integration v1",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "airtable_token": {
      "title": "Airtable API Token",
      "type": "string",
      "description": "Your Airtable Personal Access Token",
      "editor": "textfield",
      "isSecret": true
    },
    "airtable_base_id": {
      "title": "Airtable Base ID",
      "type": "string",
      "description": "The base ID (starts with 'app')",
      "editor": "textfield"
    },
    "airtable_table_name": {
      "title": "Airtable Table Name",
      "type": "string",
      "description": "Name of the table to update",
      "editor": "textfield",
      "default": "HubSpot Sync"
    },
    "record_id": {
      "title": "Airtable Record ID",
      "type": "string",
      "description": "The record ID to update with results",
      "editor": "textfield"
    },
    "linkedin_slug": {
      "title": "LinkedIn URL/Slug",
      "type": "string",
      "description": "LinkedIn profile URL or slug (highest priority)",
      "editor": "textfield"
    },
    "domain": {
      "title": "Company Domain",
      "type": "string",
      "description": "Company domain (e.g., 'acme.com') - middle priority",
      "editor": "textfield"
    },
    "search_name": {
      "title": "Search Name",
      "type": "string",
      "description": "Person's name to search for - fallback method",
      "editor": "textfield"
    },
    "expected_company": {
      "title": "Expected Company",
      "type": "string",
      "description": "Expected company name - used with search_name",
      "editor": "textfield"
    },
    "vistage_username": {
      "title": "Vistage Username",
      "type": "string",
      "description": "Your Vistage/Salesforce username",
      "editor": "textfield",
      "isSecret": false
    },
    "vistage_password": {
      "title": "Vistage Password",
      "type": "string",
      "description": "Your Vistage/Salesforce password",
      "editor": "textfield",
      "isSecret": true
    }
  },
  "required": ["airtable_token", "airtable_base_id", "record_id", "vistage_username", "vistage_password"]
}
